<UserControl x:Class="TwinkleTrayWPF.Views.MonitorSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border Padding="15" Background="Transparent">
        <StackPanel>
            <TextBlock x:Name="MonitorNameLabel" Text="Monitor Name" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="BrightnessSlider" Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="BrightnessValue" Margin="10,0,0,0"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
