<Window x:Class="TwinkleTrayWPF.Views.BrightnessFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Twinkle Tray" Width="350" Height="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual">
    
    <Border CornerRadius="12" Background="#DD1F1F1F" BorderBrush="#444" BorderThickness="1">
        <DockPanel>
            <Border DockPanel.Dock="Bottom" Height="45" Background="#222" Padding="10,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Click="OnSettingsClick" Content="Settings"/>
                </StackPanel>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Padding="10">
                    <StackPanel x:Name="MonitorList"/>
                </Border>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
