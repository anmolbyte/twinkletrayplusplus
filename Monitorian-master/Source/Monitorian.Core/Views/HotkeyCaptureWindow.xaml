<Window x:Class="Monitorian.Core.Views.HotkeyCaptureWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Assign Hotkey" Height="150" Width="350"
		WindowStartupLocation="CenterScreen"
		Background="{DynamicResource App.Background.Translucent}"
		BorderBrush="{DynamicResource App.Border.Outline}" BorderThickness="1"
		ShowInTaskbar="False" Topmost="True"
		Focusable="True">
	<Grid>
		<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
			<TextBlock Text="Press your desired key combination..."
					   Foreground="{DynamicResource App.Foreground}"
					   FontSize="16" HorizontalAlignment="Center" Margin="10"/>
			<TextBlock Text="(e.g. Ctrl + Alt + B)"
					   Foreground="{DynamicResource App.Foreground.Shadow}"
					   FontSize="12" HorizontalAlignment="Center"/>
			<TextBlock x:Name="CapturedText"
					   Foreground="{DynamicResource App.Background.Accent.StaticColor}"
					   FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
		</StackPanel>
	</Grid>
</Window>
