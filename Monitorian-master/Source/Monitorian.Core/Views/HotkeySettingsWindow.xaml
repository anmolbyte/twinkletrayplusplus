<Window x:Class="Monitorian.Core.Views.HotkeySettingsWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:controls="clr-namespace:Monitorian.Core.Views.Controls"
		xmlns:properties="clr-namespace:Monitorian.Core.Properties"
		Title="Manage Hotkeys" Height="400" Width="500"
		WindowStartupLocation="CenterScreen"
		Background="{DynamicResource App.Background.Plain}"
		Foreground="{DynamicResource App.Foreground}"
		BorderBrush="{DynamicResource App.Border.Outline}" BorderThickness="1">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Text="Global Hotkeys" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

		<ListView Grid.Row="1" x:Name="HotkeysList" Background="Transparent" BorderThickness="0"
				  ItemsSource="{Binding Settings.Hotkeys}" ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListView.ItemTemplate>
				<DataTemplate>
					<Border BorderBrush="{DynamicResource App.Border.Outline}" BorderThickness="0,0,0,1" Padding="5">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<StackPanel Grid.Column="0">
								<TextBlock Text="{Binding DisplayText}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
								
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="120"/>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="120"/>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="50"/>
									</Grid.ColumnDefinitions>

									<TextBlock Grid.Column="0" Text="Target:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource App.Foreground.Shadow}"/>
									<ComboBox Grid.Column="1" ItemsSource="{Binding DataContext.AvailableMonitors, RelativeSource={RelativeSource AncestorType=Window}}"
											  SelectedValue="{Binding TargetMonitorId}" SelectedValuePath="Id" DisplayMemberPath="Name"
											  Margin="0,0,10,0"/>

									<TextBlock Grid.Column="2" Text="Action:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource App.Foreground.Shadow}"/>
									<ComboBox Grid.Column="3" ItemsSource="{Binding DataContext.ActionTypes, RelativeSource={RelativeSource AncestorType=Window}}"
											  SelectedValue="{Binding ActionType}"
											  Margin="0,0,10,0"/>

									<TextBlock Grid.Column="4" Text="Value:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource App.Foreground.Shadow}"/>
									<TextBox Grid.Column="5" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
											 HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
								</Grid>
							</StackPanel>
							<Button Grid.Column="1" Content="Delete" Click="DeleteHotkey_Click" 
									Background="Transparent" Foreground="Red" BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
						</Grid>
					</Border>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>

		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
			<Button Content="Add Hotkey" Click="AddHotkey_Click" Padding="15,5" Margin="0,0,10,0"
					Background="{DynamicResource App.Background.Accent.StaticColor}" Foreground="White" BorderThickness="0"/>
			<Button Content="Close" Click="Close_Click" Padding="15,5"
					Background="{DynamicResource App.Background.Translucent}" Foreground="White" BorderThickness="1"/>
		</StackPanel>
	</Grid>
</Window>
